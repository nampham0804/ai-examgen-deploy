# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/

# Virtual environments
venv/
.venv/
env/

# Environment variables
.env
.env.local
.env.production
.env.*.local
!.env.example

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Data (never commit large data, keep folder structure)
data/raw/*
data/processed/*
data/vector_store/*
!data/**/.gitkeep
*.db
*.sqlite3

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test coverage
htmlcov/
.coverage
coverage.xml

# Docker
docker-compose.override.yml

# Node (frontend)
node_modules/
.next/
out/
.nuxt/
frontend/dist/
frontend/.vite/
frontend/.turbo/

# Build
*.pyc
*.pyo

# AI/tool local files - tracked structure, ignored content
.ai-log/*.jsonl
.ai-log/archive/

# Local scratch files
test.json
tmp/
temp/

# Existing repo-local workflow generated files
.github/workflows/

# Runtime-generated app files
uploads/
exports/

# Local tool config generated by assistants/editors.
# Note: files already tracked by git will still show as modified until restored or untracked.
.codex/*.local.json
.claude/*.local.json
.cursor/*.local.json
.gemini/*.local.json
