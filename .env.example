# ============================================
# AI20K Project - Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ---- LLM Configuration ----
LLM_PROVIDER=minimax
LLM_TEMPERATURE=0.7
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_SECONDS=1.5
LLM_FALLBACK_ENABLED=false
LLM_FALLBACK_PROVIDERS=nine_router,minimax

MINIMAX_API_KEY=your-minimax-key-here
MINIMAX_BASE_URL=https://api.tokenrouter.com/v1
MINIMAX_MODEL=MiniMax-M3

NINE_ROUTER_API_KEY=your-nine-router-key-here
NINE_ROUTER_BASE_URL=http://localhost:20128/v1
NINE_ROUTER_MODEL=oc/qwen3.6-plus-free

# ---- LANGFUSE TRACK LLM ----
LANGFUSE_ENABLED=true
LANGFUSE_ENV=development
LANGFUSE_PUBLIC_KEY=pk-key
LANGFUSE_SECRET_KEY=sk-key
LANGFUSE_HOST=https://cloud.langfuse.com
LLM_LOG_FULL_PROMPT=false
LLM_LOG_RESPONSE=true

# Legacy fallback names are still accepted for 9Router if already present:
# 9_ROUTER_API_KEY=
# 9_ROUTER_BASE_URL=
# 9_ROUTER_MODEL=
# 9ROUTER_API_KEY=
# 9ROUTER_BASE_URL=
# 9ROUTER_MODEL=

# ---- Database ----
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
# For SQLite development:
# DATABASE_URL=sqlite:///./data/app.db

# ---- Vector Store ----
CHROMA_PERSIST_DIR=./data/chroma
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=

# ---- App Config ----
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- LangSmith ----
LANGCHAIN_API_KEY=your-langsmith-key-here
LANGCHAIN_PROJECT=ai20k-agent
LANGCHAIN_TRACING_V2=true

# ---- Logging ----
LOG_LEVEL=INFO

# ---- AI Hook Logging ----
AI_LOG_SERVER=https://ai-logs.note.transformerlabs.ai/api/ingest
AI_LOG_API_KEY=your-ai-log-key-here
AI_LOG_DIR=.ai-log

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:8000

